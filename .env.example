# procure-ai (redesign) — backend/runtime environment. Copy to .env; never commit secrets.
# See docs/redesign/02-target-architecture.md and 09 (deploy).

# ── Persistence ───────────────────────────────────────────────────────────────
# Postgres (tokens, jobs, extracted text/docs, metrics). Backend no-ops storage without it.
# NOTE: docker-compose.prod.yml DERIVES DATABASE_URL from POSTGRES_* below (single source,
# can't drift from the db password), so in prod this value is overridden. It IS used as-is
# for local dev (docker-compose.yml). Keep the password here == POSTGRES_PASSWORD for dev.
DATABASE_URL=postgres://procure:procure@db:5432/procure
# Redis (BullMQ pipeline queues). Without it the pipeline is disabled and uploads 503.
# Also overridden by docker-compose.prod.yml (redis://redis:6379).
REDIS_URL=redis://redis:6379
# Хранилище задач публичного демо (async AI-путь, GH #78). Пусто/`memory` — in-memory,
# один процесс (дефолт; демо в проде = 1 контейнер). `redis` — общее хранилище (переживает
# рестарт, работает за балансировщиком без sticky-сессий); требует REDIS_URL выше. Включать
# ТОЛЬКО при масштабировании демо-бэкенда на >1 реплику.
DEMO_JOBSTORE=memory
# Демо: макс. параллельных AI-разборов (public /api/demo/extract) — защита от перегруза
# инференса публичной страницей. Дефолт 2.
DEMO_AI_MAX_CONCURRENCY=2
# Демо: каталог для временных файлов разбора (PDF/скан). Дефолт /tmp/procure-demo.
DEMO_TMP_DIR=/tmp/procure-demo

# ── Ресурсы воркера (минимальный профиль) ─────────────────────────────────────
# Конкуренция очередей извлечения/агента/CRM. Дефолты 4/2/4. На МИНИМАЛЬНОМ хосте
# (2 vCPU) снизьте до ≤ числа ядер — иначе несколько тяжёлых OCR разом упираются в
# 90с-таймаут (ложные ошибки). См. GH #95, docs/redesign/09-deploy §«Ресурсы воркера».
QUEUE_EXTRACT_CONCURRENCY=4
QUEUE_AGENT_CONCURRENCY=2
QUEUE_CRM_CONCURRENCY=4
# Ограничить число потоков tesseract/OpenMP (иначе один OCR разворачивается на все ядра
# и N параллельных процессов дерутся за CPU). На минимуме — 1 или 2. Пусто = дефолт tesseract.
# Пробрасываются в субпроцессы (allow-list subprocessEnv, GH #99); OMP_NUM_THREADS — синоним.
OMP_THREAD_LIMIT=
OMP_NUM_THREADS=

# ── Bitrix24 app (OAuth, multitenant) ─────────────────────────────────────────
B24_CLIENT_ID=
B24_CLIENT_SECRET=
# application_token is DELIVERED by ONAPPINSTALL and remembered per-portal (B24
# «Безопасность в обработчиках») — the first install authenticates via its access_token,
# later events verify against the stored token. So LEAVE THIS EMPTY normally. Set it only
# to add an extra global gate on first install; a placeholder here 403s every install.
B24_APPLICATION_TOKEN=
# AES-256-GCM key (base64, 32 bytes) for refresh-token encryption at rest:  openssl rand -base64 32
B24_TOKEN_ENC_KEY=
# Proactive OAuth keep-alive cadence in HOURS (#175) — refreshes only near-expiry idle
# portals so their refresh_token doesn't die on day 180. Runs on the cron/primary instance
# (QUEUE_CRON=1) and needs B24_CLIENT_ID/SECRET. Default 24; clamped to [1h, 168h].
TOKEN_KEEPALIVE_HOURS=24
# TTL (DAYS) for the portal_tombstone event-ordering guard (#77). The hourly retention sweep drops
# tombstones older than this — a months-old one can no longer be raced (B24 doesn't retry online
# events that long), so this caps growth (one row per permanently-uninstalled portal). Default 30;
# clamped to [1, 365].
TOMBSTONE_TTL_DAYS=30

# ── LLM extractor (OpenAI-compatible /v1/chat/completions, openai SDK, in-process) ────
# One transport, provider chosen by LLM_PROVIDER = deepseek | bitrixgpt | custom.
LLM_PROVIDER=deepseek
#   deepseek  — base https://api.deepseek.com/v1, model deepseek-v4-flash (jurisdiction КНР, #215).
#               Key: DEEPSEEK_API_KEY, or the legacy ANTHROPIC_AUTH_TOKEN below (same key) — so an
#               existing prod env keeps working through the claude→chat cutover with no change.
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-v4-flash
#   bitrixgpt — Bitrix Vibecode AI Router, model bitrix/bitrixgpt-5.5 (jurisdiction — Bitrix's).
#               Key is a Vibecode key (vibe_api_…); VIBE_API_KEY is also accepted.
# BITRIXGPT_API_KEY=
# VIBE_API_KEY=
# BITRIXGPT_MODEL=bitrix/bitrixgpt-5.5
#   custom    — any OpenAI-compatible endpoint (fully explicit):
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=
# LLM_LABEL=custom
# Legacy alias accepted as the deepseek key (see above) during the cutover; safe to drop later.
# ANTHROPIC_AUTH_TOKEN=

# ── Storage / misc ────────────────────────────────────────────────────────────
# Ephemeral upload dir (bytes deleted after extraction / on uninstall / by TTL sweep).
UPLOAD_DIR=/data/uploads
# crm-sync idempotency marker originator (stamped into the created entity's originId/originatorId
# or xmlId, then searched before create). Namespaces our marker so it never matches a portal's own
# external-source data. Empty → defaults to the repo code «ai-price-import».
IMPORT_ORIGINATOR_ID=

# ── Public (build-time / SSR) ─────────────────────────────────────────────────
# Absolute site URL — REQUIRED in prod (builds the B24 event-handler URL).
NUXT_PUBLIC_SITE_URL=https://price-import.bx-shef.by
# Build commit sha (CI passes github.sha); shown in health + footer.
NUXT_PUBLIC_COMMIT_SHA=dev
# Bitrix24 Market listing code override for the «оцените приложение» modal. Empty → the app's real
# slug (shef.priceimport, from landing.ts) is used. Set only to point at a different listing.
NUXT_PUBLIC_B24_MARKET_CODE=

# ── Operator login (service zone /queues) — optional ──────────────────────────
# Empty password disables operator login. Use a dedicated session secret (not the enc key).
OPERATOR_PASSWORD=
OPERATOR_SESSION_SECRET=

# ── Edge security for the no-nginx target ("black hole" Vibecode VM) ───────────
# Set to 1 ONLY when the app is directly internet-facing (no nginx in front). Then Nitro
# self-applies the security headers nginx would (CSP + B24 frame-ancestors, nosniff,
# Referrer-Policy, HSTS) and an app-level login brute-force throttle. Behind nginx leave
# it EMPTY/0 — else you get a double CSP and a login throttle keyed on the proxy IP.
APP_EDGE_SECURITY=
# Escape hatch for APP_EDGE_SECURITY. Default off → per-IP limits key on the real TCP peer
# (socket.remoteAddress), spoof-proof. Set to 1 ONLY after live-verifying the platform ingress
# (e.g. the Vibecode tunnel) is a trusted proxy that appends the real client as the LAST
# X-Forwarded-For hop — otherwise every client collapses into one bucket (demo/login lockout).
APP_EDGE_TRUST_XFF=

# ── Prod compose only (docker-compose.prod.yml) ───────────────────────────────
# Bare host for the shared nginx-proxy vhost + ACME cert (NOT a URL — no scheme/path).
# Must match the host in NUXT_PUBLIC_SITE_URL above.
DOMAIN=price-import.bx-shef.by
# TLS cert email for acme-companion (Let's Encrypt).
LETSENCRYPT_EMAIL=
# Postgres for the prod `db` service. DATABASE_URL above MUST embed the same password
# and point at host `db` (e.g. postgres://procure:<POSTGRES_PASSWORD>@db:5432/procure).
POSTGRES_USER=procure
POSTGRES_PASSWORD=
POSTGRES_DB=procure

# ── Обратная связь 👍/👎 (#182 канал «сотрудник») ──────────────────────────────
# Канал ВЫКЛЮЧЕН, пока не заданы ОБА. Токен GitHub с правом Issues → R/W. Репо —
# ОБЯЗАТЕЛЬНО приватный (комментарии сотрудников могут нести клиентский контекст;
# не указывайте публичный код-репо). Нет токена/репо → виджет скрыт, POST → 503.
GITHUB_FEEDBACK_TOKEN=
GITHUB_FEEDBACK_REPO=

# ── OpenTelemetry (телеметрия, docs/OBSERVABILITY.md) ──────────────────────────
# DEFAULT OFF: без OTEL_EXPORTER_OTLP_ENDPOINT бэкенд работает ровно как раньше
# (otel.instrument.mjs при старте ничего не поднимает). Станция сбора (коллектор +
# ClickHouse + Grafana) — отдельный деплой в telemetry-station/.
# ⚠ Указывать БАЗУ эндпоинта (без /v1/traces) — экспортёр сам добавит путь, иначе он удвоится.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# TELEMETRY_ENABLED=1                       # 0 — принудительно выключить даже при заданном эндпоинте
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer CHANGE_ME
# OTEL_SERVICE_NAME=ai-price-import-backend
# OTEL_SERVICE_VERSION=                     # по умолчанию — NUXT_PUBLIC_COMMIT_SHA
