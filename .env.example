# procure-ai (redesign) — backend/runtime environment. Copy to .env; never commit secrets.
# See docs/redesign/02-target-architecture.md and 09 (deploy).

# ── Persistence ───────────────────────────────────────────────────────────────
# Postgres (tokens, jobs, extracted text/docs, metrics). Backend no-ops storage without it.
# NOTE: docker-compose.prod.yml DERIVES DATABASE_URL from POSTGRES_* below (single source,
# can't drift from the db password), so in prod this value is overridden. It IS used as-is
# for local dev (docker-compose.yml). Keep the password here == POSTGRES_PASSWORD for dev.
DATABASE_URL=postgres://procure:procure@db:5432/procure
# Redis (BullMQ pipeline queues). Without it the pipeline is disabled and uploads 503.
# Also overridden by docker-compose.prod.yml (redis://redis:6379).
REDIS_URL=redis://redis:6379
# Хранилище задач публичного демо (async AI-путь, GH #78). Пусто/`memory` — in-memory,
# один процесс (дефолт; демо в проде = 1 контейнер). `redis` — общее хранилище (переживает
# рестарт, работает за балансировщиком без sticky-сессий); требует REDIS_URL выше. Включать
# ТОЛЬКО при масштабировании демо-бэкенда на >1 реплику.
DEMO_JOBSTORE=memory

# ── Ресурсы воркера (минимальный профиль) ─────────────────────────────────────
# Конкуренция очередей извлечения/агента/CRM. Дефолты 4/2/4. На МИНИМАЛЬНОМ хосте
# (2 vCPU) снизьте до ≤ числа ядер — иначе несколько тяжёлых OCR разом упираются в
# 90с-таймаут (ложные ошибки). См. GH #95, docs/redesign/09-deploy §«Ресурсы воркера».
QUEUE_EXTRACT_CONCURRENCY=4
QUEUE_AGENT_CONCURRENCY=2
QUEUE_CRM_CONCURRENCY=4
# Ограничить число потоков tesseract/OpenMP (иначе один OCR разворачивается на все ядра
# и N параллельных процессов дерутся за CPU). На минимуме — 1 или 2. Пусто = дефолт tesseract.
# Пробрасываются в субпроцессы (allow-list subprocessEnv, GH #99); OMP_NUM_THREADS — синоним.
OMP_THREAD_LIMIT=
OMP_NUM_THREADS=

# ── Bitrix24 app (OAuth, multitenant) ─────────────────────────────────────────
B24_CLIENT_ID=
B24_CLIENT_SECRET=
# application_token is DELIVERED by ONAPPINSTALL and remembered per-portal (B24
# «Безопасность в обработчиках») — the first install authenticates via its access_token,
# later events verify against the stored token. So LEAVE THIS EMPTY normally. Set it only
# to add an extra global gate on first install; a placeholder here 403s every install.
B24_APPLICATION_TOKEN=
# AES-256-GCM key (base64, 32 bytes) for refresh-token encryption at rest:  openssl rand -base64 32
B24_TOKEN_ENC_KEY=

# ── LLM agent (DeepSeek via an Anthropic-compatible endpoint) ─────────────────
# The agent subprocess sees ONLY these provider vars (agentSpawnEnv strips everything else).
# Verified live against the extraction prompt on ru/be/kk documents (2026-07-09):
# both deepseek-v4-flash and deepseek-v4-pro extract supplier/tax-id/items correctly.
# Default to -flash (cheaper/faster; extraction is structured), -pro for hard docs.
# The API key goes in ANTHROPIC_AUTH_TOKEN — NOT DEEPSEEK_API_KEY (Anthropic-compat gateway).
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=deepseek-v4-flash
# Headless agent CLI binary (Claude Code).
AGENT_BIN=claude

# ── Storage / misc ────────────────────────────────────────────────────────────
# Ephemeral upload dir (bytes deleted after extraction / on uninstall / by TTL sweep).
UPLOAD_DIR=/data/uploads

# ── Public (build-time / SSR) ─────────────────────────────────────────────────
# Absolute site URL — REQUIRED in prod (builds the B24 event-handler URL).
NUXT_PUBLIC_SITE_URL=https://price-import.bx-shef.by
# Build commit sha (CI passes github.sha); shown in health + footer.
NUXT_PUBLIC_COMMIT_SHA=dev

# ── Operator login (service zone /queues) — optional ──────────────────────────
# Empty password disables operator login. Use a dedicated session secret (not the enc key).
OPERATOR_PASSWORD=
OPERATOR_SESSION_SECRET=

# ── Prod compose only (docker-compose.prod.yml) ───────────────────────────────
# Bare host for the shared nginx-proxy vhost + ACME cert (NOT a URL — no scheme/path).
# Must match the host in NUXT_PUBLIC_SITE_URL above.
DOMAIN=price-import.bx-shef.by
# TLS cert email for acme-companion (Let's Encrypt).
LETSENCRYPT_EMAIL=
# Postgres for the prod `db` service. DATABASE_URL above MUST embed the same password
# and point at host `db` (e.g. postgres://procure:<POSTGRES_PASSWORD>@db:5432/procure).
POSTGRES_USER=procure
POSTGRES_PASSWORD=
POSTGRES_DB=procure
